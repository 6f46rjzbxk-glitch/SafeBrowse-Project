{
  "manifest_version": 3,
  "name": "SafeBrowse",
  "version": "2.0",
  "description": "Қауіпті веб-сайттарды анықтайтын браузер кеңейтімі",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SafeBrowse"
  }
}